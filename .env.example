# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/credit_card_db

# Security
SECRET_KEY=yoursecretkey-for-jwt-signing
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OTP Configuration
OTP_EXPIRY_MINUTES=3
FERNET_SECRET_KEY=yoursecretkey-for-encryption-if-needed

# Initial Admin User (for seeding)
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=securepassword
FIRST_ADMIN_NAME=Admin
FIRST_ADMIN_CONTACT=+910000000000

# Other Configuration
BANKING_API_SECRET=your_banking_grade_secret_key
